# Logs and local runtime
/log/*
!/log/.keep
/tmp/*
!/tmp/.keep

# Rails local storage and generated assets
/storage/*
!/storage/.keep
/public/assets
/app/assets/builds/*
!/app/assets/builds/.keep

# Local secrets and credentials
.env
.env.*
/config/master.key
/storage/private/

# Python/Ruby generated files
__pycache__/
*.pyc
/.bundle/
/vendor/bundle/

# OS/editor
.DS_Store
Thumbs.db

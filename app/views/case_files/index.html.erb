<% content_for :title, "Casos internos - Prev Lab" %>

<div class="mx-auto flex w-full max-w-7xl flex-col gap-6">
  <header class="tl-header-card p-5 sm:p-6">
    <div class="grid gap-5 sm:grid-cols-[1fr_auto] sm:items-end">
      <div>
        <p class="tl-kicker">Organizacao interna</p>
        <h1 class="tl-page-title tl-page-title--compact">Casos internos</h1>
        <p class="tl-page-subtitle mt-3 max-w-2xl">Agrupe simulacoes de validacao sem transformar o MVP em cadastro de cliente.</p>
      </div>
      <div class="flex flex-wrap gap-3">
        <%= link_to "Novo caso", new_case_file_path, class: button_classes(:primary) %>
        <%= link_to "Painel", root_path, class: button_classes %>
      </div>
    </div>
  </header>

  <section class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
    <% @case_files.each do |case_file| %>
      <article class="tl-card tl-card-hover p-5">
        <div class="flex flex-wrap items-start justify-between gap-3">
          <div>
            <h2 class="text-base font-semibold text-white"><%= case_file.name %></h2>
            <p class="tl-kicker mt-1 text-[10px]"><%= case_file.reference_code.presence || "sem codigo" %></p>
          </div>
          <span class="<%= status_badge_classes(case_file.status) %>"><%= status_label(case_file.status) %></span>
        </div>
        <p class="tl-copy mt-4 min-h-12 text-sm"><%= case_file.description.presence || "Sem descricao." %></p>
        <div class="mt-5 flex items-center justify-between border-t border-white/10 pt-4">
          <span class="tl-muted text-sm font-semibold"><%= case_file.simulations.size %> simulacoes</span>
          <%= link_to "Abrir caso", case_file_path(case_file), class: "tl-link text-sm" %>
        </div>
      </article>
    <% end %>
  </section>
</div>
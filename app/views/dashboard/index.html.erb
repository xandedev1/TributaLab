<% content_for :title, "Prev Lab" %>

<div class="mx-auto flex w-full max-w-[92rem] flex-col gap-5">
  <% if @tax_module %>
    <section class="tl-kinetic-hero tl-kinetic-hero--cockpit">
      <div class="tl-kinetic-copy">
        <p class="tl-kicker">Cockpit operacional</p>
        <div class="tl-hero-logo-plate" aria-label="Prev Lab">
          <%= image_tag "prevlab-logo-dark.png", alt: "Prev Lab", class: "tl-hero-logo" %>
        </div>
        <p class="tl-page-subtitle mt-5 max-w-md">Mesa local para revisar casos, simulacoes e rubricas eSocial com trilha auditavel.</p>
      </div>

      <div class="tl-kinetic-stage" aria-label="Visualizacao cinetica do motor fiscal">
        <svg class="tl-kinetic-svg" viewBox="0 0 620 420" role="img" aria-label="Trilhas animadas de calculo fiscal">
          <path class="tl-kinetic-path" d="M30 312 C128 174 214 176 314 248 S486 330 590 104" />
          <path class="tl-kinetic-path tl-kinetic-path--soft" d="M42 98 H154 L222 186 H320 L386 120 H558" />
          <path class="tl-kinetic-path tl-kinetic-path--soft" d="M64 358 C152 278 226 318 302 202 S458 52 574 282" />
          <path class="tl-kinetic-path" d="M86 220 L176 118 L266 224 L358 126 L494 238" />
        </svg>

        <div class="tl-core-frame" aria-hidden="true"></div>
        <span class="tl-kinetic-node" style="--x: 13%; --y: 68%; --speed: 4.8s" aria-hidden="true"></span>
        <span class="tl-kinetic-node" style="--x: 30%; --y: 30%; --speed: 6.2s" aria-hidden="true"></span>
        <span class="tl-kinetic-node" style="--x: 53%; --y: 55%; --speed: 5.4s" aria-hidden="true"></span>
        <span class="tl-kinetic-node" style="--x: 75%; --y: 24%; --speed: 7s" aria-hidden="true"></span>
        <span class="tl-kinetic-node" style="--x: 84%; --y: 70%; --speed: 5.8s" aria-hidden="true"></span>
      </div>
    </section>
  <% else %>
    <section class="tl-kinetic-hero tl-kinetic-hero--cockpit">
      <div class="tl-kinetic-copy">
        <p class="tl-kicker">Preparacao pendente</p>
        <div class="tl-hero-logo-plate" aria-label="Prev Lab">
          <%= image_tag "prevlab-logo-dark.png", alt: "Prev Lab", class: "tl-hero-logo" %>
        </div>
        <p class="tl-page-subtitle mt-5">Rode <span class="tl-mono">ruby bin/rails db:seed</span> para carregar o modulo fiscal inicial.</p>
      </div>
      <div class="tl-kinetic-stage" aria-hidden="true"><div class="tl-core-frame"></div></div>
    </section>
  <% end %>
</div>

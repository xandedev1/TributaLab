<% content_for :title, "Tabelas eSocial CTE - Prev Lab" %>

<div class="mx-auto flex w-full max-w-[96rem] flex-col gap-6">
  <header class="tl-command-bar">
    <div class="grid gap-5 xl:grid-cols-[1fr_auto] xl:items-end">
      <div>
        <p class="tl-kicker">eSocial / CTE</p>
        <h1 class="tl-page-title tl-page-title--compact">Tabelas da CTE</h1>
        <p class="tl-page-subtitle mt-3 max-w-3xl">Status direto das duas tabelas pedidas: S-1005 Estabelecimentos/Obras e S-1020 Lotacao Tributaria.</p>
      </div>
      <div class="flex flex-wrap gap-2 xl:justify-end">
        <span class="tl-chip tl-chip--success"><%= @snapshot.official_used_label %></span>
        <span class="tl-chip <%= @snapshot.preflight.ready_for_official_query? ? "tl-chip--success" : "tl-chip--warning" %>"><%= @snapshot.preflight.ready_for_official_query? ? "certificado pronto" : "certificado pendente" %></span>
        <span class="tl-chip tl-chip--info">S-1005 + S-1020</span>
        <%= link_to "Certificado", esocial_certificado_path, class: button_classes(:info) %>
      </div>
    </div>
  </header>

  <section class="tl-panel p-5">
    <div class="grid gap-4 lg:grid-cols-[1fr_auto] lg:items-center">
      <div>
        <p class="tl-kicker">Acesso oficial</p>
        <h2 class="tl-section-title mt-1"><%= @snapshot.preflight.official_gate_title %></h2>
        <p class="tl-copy mt-3 text-sm">Executa busca oficial em producao para S-1005 e S-1020 com limite local de 2 chamadas nesta rodada. A tela prioriza XMLs baixados agora pelo eSocial quando eles existirem.</p>
      </div>
      <div class="flex flex-wrap gap-2 lg:justify-end">
        <%= form_with url: esocial_sync_runs_path, method: :post, data: { turbo: false } do %>
          <%= hidden_field_tag :max_queries, 2 %>
          <%= submit_tag "Executar ate 2 consultas", class: button_classes(:primary), data: { turbo_confirm: "Executar ate 2 chamadas oficiais no eSocial agora?" } %>
        <% end %>
        <%= link_to "Certificado", esocial_certificado_path, class: button_classes(:info) %>
      </div>
    </div>
  </section>

  <section class="tl-panel p-5">
    <div class="grid gap-4 lg:grid-cols-[0.8fr_1.2fr] lg:items-start">
      <div>
        <p class="tl-kicker">O que aconteceu</p>
        <h2 class="tl-section-title mt-1"><%= @snapshot.official_title %></h2>
        <p class="tl-copy mt-3 text-sm"><%= @snapshot.official_detail %></p>
      </div>
      <div class="grid gap-3 sm:grid-cols-2">
        <div class="tl-tile p-4">
          <p class="tl-metric-label">Resultado pratico</p>
          <p class="tl-copy mt-2 text-sm font-semibold text-white"><%= @snapshot.official_title %></p>
        </div>
        <div class="tl-tile p-4">
          <p class="tl-metric-label">Fonte exibida</p>
          <p class="tl-copy mt-2 text-sm font-semibold text-white">Prioridade para XML baixado agora; fallback para XML oficial local.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="grid gap-4 lg:grid-cols-2">
    <% @snapshot.table_statuses.each do |table| %>
      <article class="tl-panel p-5">
        <div class="flex flex-wrap items-start justify-between gap-3">
          <div>
            <p class="tl-kicker"><%= table.event_code %></p>
            <h2 class="tl-section-title mt-1"><%= table.label %></h2>
          </div>
          <span class="<%= table.loaded? ? "tl-badge tl-badge--success" : "tl-badge tl-badge--warning" %>"><%= table.result_label %></span>
        </div>

        <div class="mt-5 grid gap-3 sm:grid-cols-2">
          <div class="tl-tile p-4">
            <p class="tl-metric-label">Eventos carregados</p>
            <p class="tl-metric-value"><%= table.rows_count %></p>
          </div>
          <div class="tl-tile p-4">
            <p class="tl-metric-label">Fonte</p>
            <p class="tl-copy mt-2 text-sm font-semibold text-white"><%= table.source_label %></p>
          </div>
        </div>

        <p class="tl-copy mt-4 text-sm"><%= table.result_detail %></p>
        <p class="tl-muted mt-2 text-xs"><%= table.source_detail %></p>

        <details class="tl-reveal-drawer mt-5">
          <summary>Fonte oficial</summary>
          <div class="tl-reveal-body space-y-4">
          <div>
            <p class="tl-kicker">Disclaimer tecnico</p>
            <p class="tl-copy mt-2 text-sm font-semibold text-white"><%= table.source_disclosure.headline %></p>
          </div>

          <dl class="grid gap-3">
            <% table.source_disclosure.items.each do |label, value| %>
            <div>
              <dt class="tl-metric-label"><%= label %></dt>
              <dd class="tl-copy mt-1 text-sm"><%= value %></dd>
            </div>
            <% end %>
          </dl>

          <% if table.source_disclosure.source_paths.any? %>
            <div>
            <p class="tl-metric-label">Caminho fonte</p>
            <ul class="mt-2 grid gap-2">
              <% table.source_disclosure.source_paths.each do |source_path| %>
              <li class="tl-muted break-all text-xs"><%= source_path %></li>
              <% end %>
            </ul>
            </div>
          <% end %>
          </div>
        </details>

        <div class="mt-5">
          <%= link_to "Abrir #{table.label}", table.path, class: button_classes(:info) %>
        </div>
      </article>
    <% end %>
  </section>

  <section class="tl-panel p-5">
    <div class="grid gap-4 lg:grid-cols-[1fr_auto] lg:items-center">
      <div>
        <h2 class="tl-section-title">Resposta curta</h2>
      <p class="tl-copy mt-2 text-sm">Quando a execucao oficial baixar XML, S-1005 e S-1020 passam a vir do eSocial agora. Sem XML novo, a tela mostra claramente o log da chamada e cai no XML oficial local.</p>
      </div>
      <%= link_to "Ver Estabelecimentos", esocial_estabelecimentos_obras_path, class: button_classes(:primary) %>
    </div>
  </section>
</div>

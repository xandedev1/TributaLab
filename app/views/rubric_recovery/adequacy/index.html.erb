<% content_for :title, "Adequacao S-1010 via Pontuacao - Prev Lab" %>

<div class="mx-auto flex w-full max-w-[96rem] flex-col gap-6">
  <header class="tl-command-bar">
    <div class="grid gap-5 lg:grid-cols-[1fr_auto] lg:items-end">
      <div>
        <p class="tl-kicker">Folha eSocial / Adequacao cadastral</p>
        <h1 class="tl-page-title tl-page-title--compact">Pontuacao de Naturezas</h1>
        <p class="tl-page-subtitle mt-3 max-w-3xl">Lista os eventos CTE e sugere naturezas da Tabela 03 com score deterministico, sinais positivos, penalidades e revisao humana.</p>
      </div>
      <div class="flex flex-wrap gap-2">
        <span class="tl-chip tl-chip--info">Eventos / S-1010</span>
        <span class="tl-chip tl-chip--ghost">Etapa 004C</span>
      </div>
    </div>
  </header>

  <nav class="tl-section-tabs" aria-label="Navegacao S-1010">
    <%= link_to "Pontuacao S-1010", rubric_recovery_adequacy_path, class: s1010_tab_classes(rubric_recovery_adequacy_path) %>
    <%= link_to "Rubricas + Natureza", rubric_recovery_rubrics_natures_path, class: s1010_tab_classes(rubric_recovery_rubrics_natures_path) %>
  </nav>

  <section class="grid gap-4 md:grid-cols-2 xl:grid-cols-5">
    <% @metrics.each do |metric| %>
      <article class="tl-card tl-card-hover p-4">
        <p class="tl-metric-label"><%= metric[:label] %></p>
        <p class="tl-metric-value"><%= metric[:value] %></p>
        <p class="tl-copy mt-2 text-xs"><%= metric[:detail] %></p>
      </article>
    <% end %>
  </section>

  <section class="tl-panel p-5">
    <%= form_with url: rubric_recovery_adequacy_path, method: :get, data: { turbo: false }, class: "grid gap-4 lg:grid-cols-[1.2fr_1fr_auto] lg:items-end" do %>
      <div>
        <%= label_tag :q, "Buscar rubrica", class: "tl-label" %>
        <%= text_field_tag :q, @query, class: "tl-input", placeholder: "Codigo ou descricao" %>
      </div>
      <div>
        <%= label_tag :status, "Status", class: "tl-label" %>
        <%= select_tag :status, options_for_select([["Todos", ""], ["Sem natureza", "sem natureza"], ["Sugestao alta", "sugestao alta"], ["Ambigua", "ambigua"], ["Selecionada", "selected"], ["Revisar", "revisar"]], @status), class: "tl-input" %>
      </div>
      <div class="flex gap-2">
        <%= submit_tag "Filtrar", class: button_classes(:primary) %>
        <%= link_to "Limpar", rubric_recovery_adequacy_path, class: button_classes %>
      </div>
    <% end %>
  </section>

  <section class="tl-panel overflow-hidden">
    <div class="tl-panel-header flex flex-col gap-2 lg:flex-row lg:items-center lg:justify-between">
      <div>
        <h2 class="tl-section-title">Eventos CTE</h2>
        <p class="tl-panel-subtitle">Cada linha tem top 10 de naturezas candidatas preservando duplicidades por vigencia.</p>
      </div>
      <span class="tl-chip tl-chip--ghost"><%= @events.size %> eventos na lista</span>
    </div>

    <div class="tl-table-wrap">
      <table class="tl-table">
        <thead>
          <tr>
            <th>Codigo</th>
            <th>Rubrica CTE</th>
            <th>Indicadores</th>
            <th>Status</th>
            <th>Melhor candidata</th>
            <th>Score</th>
            <th>Candidatas</th>
            <th>Acao</th>
          </tr>
        </thead>
        <tbody>
          <% @events.each do |event| %>
            <% best = event.best_suggestion %>
            <tr class="<%= event.assigned? ? "tl-row-selected" : (event.ambiguous_suggestions? ? "tl-row-warning" : nil) %>">
              <td class="whitespace-nowrap tl-mono text-xs"><%= event.event_code %></td>
              <td class="min-w-72">
                <p class="font-semibold text-white"><%= event.description %></p>
                <p class="tl-muted mt-1 text-xs">Tp. <%= event.tp.presence || "-" %> / Nt. <%= event.nt.presence || "-" %> / Tab. <%= event.table_code.presence || "-" %></p>
              </td>
              <td>
                <div class="flex flex-wrap gap-2">
                  <span class="tl-chip">InM <%= event.inm.presence || "-" %></span>
                  <span class="tl-chip">IrM <%= event.irm.presence || "-" %></span>
                  <span class="tl-chip">FN <%= event.fn.presence || "-" %></span>
                </div>
              </td>
              <td><span class="<%= status_badge_classes(event.adequacy_status) %>"><%= status_label(event.adequacy_status) %></span></td>
              <td class="min-w-80">
                <% if best %>
                  <p class="font-semibold text-white"><%= best.esocial_nature.nature_code %> - <%= best.esocial_nature.name %></p>
                  <p class="tl-muted mt-1 text-xs"><%= best.esocial_nature.vigency_label %></p>
                <% else %>
                  <span class="tl-muted">Sem sugestao</span>
                <% end %>
              </td>
              <td>
                <% if best %>
                  <div class="tl-score-stack">
                    <span class="<%= score_badge_classes(best.score) %>"><%= number_with_precision(best.score, precision: 2) %></span>
                    <div class="<%= score_bar_classes(best.score) %>" aria-label="Score <%= number_with_precision(best.score, precision: 2) %> de 10">
                      <span style="width: <%= score_percentage(best.score) %>%"></span>
                    </div>
                  </div>
                <% else %>
                  <span class="tl-muted">-</span>
                <% end %>
              </td>
              <td><span class="tl-badge tl-badge--warning"><%= event.relevant_suggestions_count %></span></td>
              <td><%= link_to event.assigned? ? "Revisar" : "Avaliar", rubric_recovery_adequacy_event_path(event), class: "tl-link" %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>
</div>
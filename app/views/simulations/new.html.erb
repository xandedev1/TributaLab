<% content_for :title, "Nova simulacao - TributaLab" %>

<div class="mx-auto flex w-full max-w-5xl flex-col gap-6">
  <header class="border-b border-zinc-200 pb-5">
    <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="text-sm font-medium uppercase tracking-wide text-teal-700">TributaLab</p>
        <h1 class="mt-1 text-3xl font-semibold tracking-normal text-zinc-950">Nova simulacao</h1>
        <p class="mt-2 text-sm leading-6 text-zinc-600">Reforma Tributaria Imobiliaria / versao <%= @tax_rule_version&.code || "sem versao" %></p>
      </div>
      <%= link_to "Voltar ao painel", root_path, class: "w-fit rounded border border-zinc-300 bg-white px-4 py-2 text-sm font-semibold text-zinc-700 hover:bg-zinc-100" %>
    </div>
  </header>

  <% if @error_message.present? %>
    <section class="border border-red-300 bg-red-50 p-4 text-sm text-red-900">
      <p class="font-semibold">Nao foi possivel salvar a simulacao.</p>
      <p class="mt-1"><%= @error_message %></p>
    </section>
  <% end %>

  <section class="border border-zinc-200 bg-white p-5">
    <%= form_with url: simulations_path, method: :post, data: { turbo: false }, class: "grid gap-6" do %>
      <div class="grid gap-4 lg:grid-cols-2">
        <div>
          <%= label_tag :name, "Nome da simulacao", class: "block text-sm font-semibold text-zinc-800" %>
          <%= text_field_tag :name, params[:name], placeholder: "Opcional", class: "mt-2 w-full rounded border border-zinc-300 px-3 py-2 text-sm" %>
        </div>
        <div>
          <%= label_tag :operation_code, "Operacao", class: "block text-sm font-semibold text-zinc-800" %>
          <%= select_tag :operation_code, options_from_collection_for_select(@operations, :code, :name, @selected_operation_code), class: "mt-2 w-full rounded border border-zinc-300 px-3 py-2 text-sm" %>
        </div>
      </div>

      <div class="grid gap-4 lg:grid-cols-2">
        <fieldset class="border border-zinc-200 p-4">
          <legend class="px-1 text-sm font-semibold text-zinc-950">Venda de imovel ou lote</legend>
          <%= label_tag "inputs_sale_amount", "Valor da venda", class: "mt-3 block text-sm font-medium text-zinc-700" %>
          <%= number_field_tag "inputs[sale_amount]", @inputs[:sale_amount], step: "0.01", min: "0", class: "mt-2 w-full rounded border border-zinc-300 px-3 py-2 text-sm" %>
        </fieldset>

        <fieldset class="border border-zinc-200 p-4">
          <legend class="px-1 text-sm font-semibold text-zinc-950">Locacao de imoveis</legend>
          <div class="grid gap-3 sm:grid-cols-3">
            <div>
              <%= label_tag "inputs_monthly_rent", "Aluguel", class: "block text-sm font-medium text-zinc-700" %>
              <%= number_field_tag "inputs[monthly_rent]", @inputs[:monthly_rent], step: "0.01", min: "0", class: "mt-2 w-full rounded border border-zinc-300 px-3 py-2 text-sm" %>
            </div>
            <div>
              <%= label_tag "inputs_iptu_amount", "IPTU", class: "block text-sm font-medium text-zinc-700" %>
              <%= number_field_tag "inputs[iptu_amount]", @inputs[:iptu_amount], step: "0.01", min: "0", class: "mt-2 w-full rounded border border-zinc-300 px-3 py-2 text-sm" %>
            </div>
            <div>
              <%= label_tag "inputs_condominium_amount", "Condominio", class: "block text-sm font-medium text-zinc-700" %>
              <%= number_field_tag "inputs[condominium_amount]", @inputs[:condominium_amount], step: "0.01", min: "0", class: "mt-2 w-full rounded border border-zinc-300 px-3 py-2 text-sm" %>
            </div>
          </div>
          <p class="mt-3 text-sm leading-6 text-amber-800">A formula usa aluguel menos IPTU e condominio, mas este ponto segue pendente de validacao.</p>
        </fieldset>

        <fieldset class="border border-zinc-200 p-4 lg:col-span-2">
          <legend class="px-1 text-sm font-semibold text-zinc-950">Permuta com torna</legend>
          <div class="grid gap-3 sm:grid-cols-2">
            <div>
              <%= label_tag "inputs_boot_amount", "Valor da torna", class: "block text-sm font-medium text-zinc-700" %>
              <%= number_field_tag "inputs[boot_amount]", @inputs[:boot_amount], step: "0.01", min: "0", class: "mt-2 w-full rounded border border-zinc-300 px-3 py-2 text-sm" %>
            </div>
            <div>
              <%= label_tag "inputs_credits_amount", "Creditos informados", class: "block text-sm font-medium text-zinc-700" %>
              <%= number_field_tag "inputs[credits_amount]", @inputs[:credits_amount], step: "0.01", min: "0", class: "mt-2 w-full rounded border border-zinc-300 px-3 py-2 text-sm" %>
            </div>
          </div>
        </fieldset>
      </div>

      <div class="flex flex-wrap items-center justify-end gap-3 border-t border-zinc-200 pt-4">
        <%= link_to "Cancelar", root_path, class: "rounded border border-zinc-300 bg-white px-4 py-2 text-sm font-semibold text-zinc-700 hover:bg-zinc-100" %>
        <%= submit_tag "Calcular e salvar", class: "rounded bg-zinc-950 px-4 py-2 text-sm font-semibold text-white hover:bg-zinc-800" %>
      </div>
    <% end %>
  </section>
</div>